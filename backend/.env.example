# Database URL (для Render используйте PostgreSQL из dashboard)
DATABASE_URL="postgresql://username:password@host:port/dbname"

# JWT Secret (генерируйте надежный ключ)
JWT_SECRET=your-super-secure-jwt-secret-here

# Google OAuth (обновите значения для production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-app-domain.onrender.com/auth/google/callback

# Frontend URL (для Vercel или вашего домена)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key

# Port (обычно 3000, но можно переопределить)
PORT=3000
