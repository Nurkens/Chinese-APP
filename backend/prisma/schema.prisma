// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  password  String?
  username  String   @unique
  tag       String   @unique // format: "username#1234"
  avatar    String? // emoji, URL, or base64 data URI
  isGuest   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  progress      UserProgress?
  settings      UserSettings?
  learnedWords  UserWord[]
  conversations Conversation[]
  friends       Friendship[]   @relation("UserFriends")
  friendOf      Friendship[]   @relation("FriendOf")

  @@map("users")
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  notificationsEnabled Boolean @default(true)
  reminderEnabled      Boolean @default(false)
  reminderTime         String  @default("19:00") // HH:MM 24h format
  soundEnabled         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@map("friendships")
}

model UserProgress {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStudyDate DateTime?
  hskLevel      Int       @default(1) // 1-6
  totalWords    Int       @default(0) // Total words learned
  targetWords   Int       @default(1200) // Target for current HSK level

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_progress")
}

model Word {
  id            String   @id @default(uuid())
  chinese       String   @unique
  pinyin        String
  translation   String
  example       String?
  examplePinyin String?
  hskLevel      Int // 1-6
  category      String? // e.g., "noun", "verb", etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  learnedBy UserWord[]

  @@map("words")
}

model UserWord {
  id     String @id @default(uuid())
  userId String
  wordId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  // Legacy fields
  mastery     Int       @default(0) // 0-100
  reviewCount Int       @default(0)
  lastReview  DateTime?
  nextReview  DateTime?

  // SM-2 SRS fields
  easeFactor     Float    @default(2.5) // EF starts at 2.5, min 1.3
  interval       Int      @default(0) // Days until next review
  repetitions    Int      @default(0) // Successful reviews in a row
  nextReviewDate DateTime @default(now()) // When card is due
  lastReviewDate DateTime @default(now()) // Last review timestamp

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, wordId])
  @@index([userId, nextReviewDate]) // For efficient due cards query
  @@map("user_words")
}

model DailyWord {
  id        String   @id @default(uuid())
  wordId    String
  date      DateTime @unique @default(now())
  createdAt DateTime @default(now())

  @@map("daily_words")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("New conversation")
  summary   String?  @db.Text // rolling summary for long convos
  model     String?  // model id used (informational)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant" | "system"
  content        String       @db.Text
  tokensApprox   Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

model KnowledgeChunk {
  id        String   @id @default(uuid())
  source    String   // "hsk_word" | "grammar" | "app_help"
  refId     String?  // word id, grammar rule slug, etc.
  title     String
  content   String   @db.Text
  hskLevel  Int?
  hash      String   @unique // sha256 of model+content — skip re-embed
  embedding Float[]  // raw vector
  model     String   // embedding model used
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@map("knowledge_chunks")
}
